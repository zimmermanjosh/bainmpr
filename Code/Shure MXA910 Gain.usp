CHANGE Level_Lobe_1
{
    Integer lobe1_val;
	lobe1_val = (((Level_Lobe_1)*(Max_Level_Lobe_1 - Min_Level_Lobe_1)) / range);
	COMMAND_TX$ = "< SET 1 AUDIO_GAIN_HI_RES " + itoa(lobe1_val + Min_Level_Lobe_1) + " >";

}

