// DIGITAL_INPUT 
ANALOG_INPUT Level_Lobe_1,Min_Level_Lobe_1,Max_Level_Lobe_1,
_SKIP_,Level_Lobe_2,Min_Level_Lobe_2,Max_Level_Lobe_2,
_SKIP_,Level_Lobe_3,Min_Level_Lobe_3,Max_Level_Lobe_3,
_SKIP_,Level_Lobe_4,Min_Level_Lobe_4,Max_Level_Lobe_4,
_SKIP_,Level_Lobe_5,Min_Level_Lobe_5,Max_Level_Lobe_5,
_SKIP_,Level_Lobe_6,Min_Level_Lobe_6,Max_Level_Lobe_6,
_SKIP_,Level_Lobe_7,Min_Level_Lobe_7,Max_Level_Lobe_7,
_SKIP_,Level_Lobe_8,Min_Level_Lobe_8,Max_Level_Lobe_8,
_SKIP_,Level_Automix_Out,Min_Level_Automix_Out,Max_Level_Automix_Out;

// STRING_INPUT 
// BUFFER_INPUT

// DIGITAL_OUTPUT 
// ANALOG_OUTPUT 
STRING_OUTPUT COMMAND_TX$;

