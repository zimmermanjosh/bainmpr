/*******************************************************************************************
  DIGITAL, ANALOG and SERIAL INPUTS and OUTPUTS
*******************************************************************************************/
DIGITAL_INPUT _skip_, Show, Mode12, Mode23, Mode34; 
// ANALOG_INPUT 
STRING_INPUT _skip_, DMin1[3][35];
STRING_INPUT _skip_, DMin2[3][35];
STRING_INPUT _skip_, DMin3[3][35];
STRING_INPUT _skip_, DMin4[3][35], _skip_;


// BUFFER_INPUT 

DIGITAL_OUTPUT _skip_, show_FB;
// ANALOG_OUTPUT 
STRING_OUTPUT _skip_, DM_out;


/*******************************************************************************************
  Parameters
*******************************************************************************************/
// INTEGER_PARAMETER
// STRING_PARAMETER


/*******************************************************************************************
  Parameter Properties
*******************************************************************************************/
